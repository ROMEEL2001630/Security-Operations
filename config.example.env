# Copy to .env and export before using --enrich or hosted --llm.
# All are optional; the tool runs fully offline without them.
# Never commit real keys. .env is git-ignored.

# Free tier: https://www.abuseipdb.com  (1,000 checks/day)
ABUSEIPDB_API_KEY=

# Free tier: https://www.virustotal.com  (500 lookups/day)
VT_API_KEY=

# Local, free LLM via Ollama (https://ollama.com). Run: ollama run llama3
OLLAMA_MODEL=llama3

# Optional hosted LLM instead of Ollama
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
